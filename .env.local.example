# ==============================================================================
# .env.local.example
# ==============================================================================
# Copy this file to .env.local and fill in the real values.
# .env.local is gitignored — it never leaves your machine.
# ==============================================================================

# ------------------------------------------------------------------------------
# Payload secret — signs JWT tokens for admin sessions.
# (SECRET) Generate a random 64+ character string:
#   openssl rand -base64 48
# ------------------------------------------------------------------------------
PAYLOAD_SECRET=

# ------------------------------------------------------------------------------
# Site URL — where the site is hosted. For local dev, leave as-is.
# (SAFE)
# ------------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ------------------------------------------------------------------------------
# Postgres connection string.
# (SECRET — contains your database password)
#
# Local Postgres example:
#   postgresql://postgres:postgres@localhost:5432/emmerdale_marketplace
# ------------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/emmerdale_marketplace
