# ==============================================================================
# .env.local.example — Emmerdale Marketplace
# ==============================================================================
# Copy to .env.local and fill in. .env.local is gitignored — never commit it.
# Canonical set per spec Section 12.5. Mirror these into Vercel → Settings →
# Environment Variables for deployment.
# ==============================================================================

# ------------------------------------------------------------------------------
# Supabase — from Project Settings → API
# ------------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=          # safe to expose; RLS is the guard
SUPABASE_SERVICE_ROLE_KEY=              # server-only. NEVER prefix NEXT_PUBLIC.
                                        # Used by admin routes + Edge Functions.

# ------------------------------------------------------------------------------
# Resend — transactional email
# ------------------------------------------------------------------------------
RESEND_API_KEY=re_...
# Sender on the verified domain. Nothing delivers until Resend DNS verification
# on emmerdaleagriculture.com is complete (spec 12.4). For a local test before
# DNS, temporarily use onboarding@resend.dev.
EMAIL_FROM=Emmerdale Agriculture <network@emmerdaleagriculture.com>

# ------------------------------------------------------------------------------
# App
# ------------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://emmerdaleagriculture.com   # http://localhost:3000 for dev
ADMIN_EMAILS=tom@example.com            # comma-separated; grants the is_admin claim

# ------------------------------------------------------------------------------
# Tooling only (optional) — direct Postgres connection for running SQL/psql.
# Not used by the app runtime (the app uses the Supabase client libraries).
# ------------------------------------------------------------------------------
# DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# ------------------------------------------------------------------------------
# Phase 4 only — Stripe. Leave unset until then.
# ------------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_ID=

# ------------------------------------------------------------------------------
# Facebook-leads intake (POST /api/leads)
# (SECRET) Shared secret the webhook caller (Zapier/Make/Meta) must send in the
# x-webhook-secret header. Generate: openssl rand -hex 24
# ------------------------------------------------------------------------------
LEADS_WEBHOOK_SECRET=
